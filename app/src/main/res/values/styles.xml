<resources>
    <style name="Widget.Spotify.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/spotify_surface_alt</item>
        <item name="boxStrokeColor">@color/spotify_surface_line</item>
        <item name="hintTextColor">@color/spotify_text_secondary</item>
        <item name="android:textColorHint">@color/spotify_text_secondary</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
    </style>

    <style name="Widget.Spotify.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/spotify_text_primary</item>
        <item name="android:textColorHint">@color/spotify_text_secondary</item>
    </style>

    <style name="Widget.Spotify.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/spotify_green</item>
        <item name="android:textColor">@color/spotify_black</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <style name="Widget.Spotify.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/spotify_surface_alt</item>
        <item name="android:textColor">@color/spotify_text_primary</item>
        <item name="strokeColor">@color/spotify_surface_line</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <style name="Widget.Sonic.AuthInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="hintEnabled">false</item>
        <item name="boxBackgroundColor">@color/sonic_surface_soft</item>
        <item name="boxStrokeColor">@color/sonic_surface_line_bright</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCollapsedPaddingTop">0dp</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="helperTextTextColor">@color/sonic_text_tertiary</item>
        <item name="errorTextColor">@color/sonic_label</item>
        <item name="placeholderTextColor">@color/sonic_text_tertiary</item>
    </style>

    <style name="Widget.Sonic.AuthInputEditText" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:textColor">@color/sonic_text_primary</item>
        <item name="android:textColorHint">@color/sonic_text_tertiary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.Sonic.AuthPrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">58dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/sonic_lilac</item>
        <item name="android:textColor">@color/sonic_button_text</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Sonic.AuthSecondaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/sonic_surface_soft</item>
        <item name="android:textColor">@color/sonic_text_primary</item>
        <item name="strokeColor">@color/sonic_surface_line</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.Sonic.AuthTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/sonic_lilac</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@color/sonic_lilac_glow</item>
    </style>
</resources>
