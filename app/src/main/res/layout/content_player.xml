<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="@drawable/bg_album_placeholder"
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/playerArtworkImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/playerInitialText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/spotify_text_primary"
                android:textSize="72sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/playerTrackTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/spotify_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/playerLikeButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/player_like"
                android:padding="10dp"
                android:src="@drawable/ic_favorite_border"
                app:tint="@color/spotify_text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/playerArtistText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/spotify_text_secondary"
            android:textSize="16sp" />

        <SeekBar
            android:id="@+id/playerSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:max="1000"
            android:progressTint="@color/spotify_green"
            android:thumbTint="@color/spotify_green" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/playerCurrentTimeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/spotify_text_tertiary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/playerDurationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/spotify_text_tertiary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/playerShuffleButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/player_shuffle"
                android:padding="14dp"
                android:src="@drawable/ic_shuffle"
                app:tint="@color/spotify_text_primary" />

            <ImageButton
                android:id="@+id/playerPreviousButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/offline_skip_previous"
                android:padding="16dp"
                android:src="@drawable/ic_previous"
                app:tint="@color/spotify_text_primary" />

            <ImageButton
                android:id="@+id/playerToggleButton"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_player_primary"
                android:contentDescription="@string/offline_pause_track"
                android:padding="24dp"
                android:src="@drawable/ic_pause" />

            <ImageButton
                android:id="@+id/playerNextButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/offline_skip_next"
                android:padding="16dp"
                android:src="@drawable/ic_next"
                app:tint="@color/spotify_text_primary" />

            <ImageButton
                android:id="@+id/playerRepeatButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/player_repeat"
                android:padding="14dp"
                android:src="@drawable/ic_repeat"
                app:tint="@color/spotify_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_section_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_queue_label"
                android:textColor="@color/spotify_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/playerQueueInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/spotify_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
