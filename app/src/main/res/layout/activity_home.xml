<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_backdrop">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/headerGreetingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/spotify_text_primary"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/headerSubtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/home_downloaded_only"
                    android:textColor="@color/spotify_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/authBadgeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="@string/home_auth_badge"
                android:textColor="@color/spotify_green"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/offlineModeButton"
                style="@style/Widget.Spotify.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_offline" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/onlineModeButton"
                style="@style/Widget.Spotify.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/mode_online" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1">

            <include
                android:id="@+id/dashboardView"
                layout="@layout/content_home_dashboard" />

            <include
                android:id="@+id/searchView"
                layout="@layout/content_search" />

            <include
                android:id="@+id/playerView"
                layout="@layout/content_player" />

            <include
                android:id="@+id/profileView"
                layout="@layout/content_profile" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/miniPlayerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_mini_player"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_album_placeholder"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/miniPlayerArtworkImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/miniPlayerInitialText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/spotify_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/miniPlayerTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textColor="@color/spotify_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/miniPlayerArtistText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:textColor="@color/spotify_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/miniPlayerToggleButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/offline_pause_track"
                android:padding="10dp"
                android:src="@drawable/ic_pause_light"
                app:tint="@color/spotify_text_primary" />

            <ImageButton
                android:id="@+id/miniPlayerNextButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_player_secondary"
                android:contentDescription="@string/offline_skip_next"
                android:padding="10dp"
                android:src="@drawable/ic_next"
                app:tint="@color/spotify_text_primary" />
        </LinearLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_section_card"
            app:itemIconTint="@color/nav_item_tint"
            app:itemTextColor="@color/nav_item_tint"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_bottom_nav" />
    </LinearLayout>

    <include
        android:id="@+id/loadingView"
        layout="@layout/view_loading_overlay" />
</FrameLayout>
