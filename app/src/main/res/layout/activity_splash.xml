<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_sonic_auth_scene"
    android:padding="6dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_sonic_screen_frame" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="36dp"
        android:paddingEnd="28dp"
        android:paddingBottom="28dp">

        <Space
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1.2" />

        <FrameLayout
            android:layout_width="168dp"
            android:layout_height="168dp"
            android:background="@drawable/bg_sonic_brand_tile"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_sonic_disc" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:letterSpacing="-0.02"
            android:lineSpacingExtra="-2sp"
            android:text="@string/auth_brand_display"
            android:textColor="@color/sonic_lilac"
            android:textSize="32sp"
            android:textStyle="bold|italic" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:alpha="0.6"
                android:background="@color/sonic_surface_line_bright" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.22"
                android:text="@string/auth_brand_established"
                android:textColor="@color/sonic_text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:alpha="0.6"
                android:background="@color/sonic_surface_line_bright" />
        </LinearLayout>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/auth_splash_caption"
            android:textColor="@color/sonic_text_primary"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_sonic_dot_active" />

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginStart="7dp"
                android:background="@drawable/bg_sonic_dot_active" />

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginStart="7dp"
                android:background="@drawable/bg_sonic_dot_active" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:text="@string/auth_feature_lossless"
                android:textColor="@color/sonic_text_tertiary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:text="@string/auth_feature_spatial"
                android:textColor="@color/sonic_text_tertiary"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:text="@string/auth_feature_studio"
                android:textColor="@color/sonic_text_tertiary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
